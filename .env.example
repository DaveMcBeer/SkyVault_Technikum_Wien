# Flask Configuration
# Use 'development' for local development only; set 'production' for all deployments
FLASK_ENV=production
SECRET_KEY=your-secret-key-here-change-this-in-production
ENCRYPTION_KEY=<dein-fernet-key>

# File Storage
UPLOAD_FOLDER=uploads
ENCRYPTED_FOLDER=encrypted_files

# Security
BCRYPT_LOG_ROUNDS=12

# Database (if using)
DATABASE_URL=sqlite:///skyvault.db

# WebAuthn / FIDO2 — change these for your production domain
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=SkyVault
# Must use HTTPS in production (e.g. https://yourdomain.com)
WEBAUTHN_ORIGIN=https://yourdomain.com

# Set to 'True' only when the app is behind a TLS-terminating proxy (enables HSTS + HTTP→HTTPS redirect)
ENABLE_HTTPS=False

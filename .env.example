# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-here-change-this-in-production
ENCRYPTION_KEY=<dein-fernet-key>

# File Storage
UPLOAD_FOLDER=uploads
ENCRYPTED_FOLDER=encrypted_files

# Security
BCRYPT_LOG_ROUNDS=12

# Database (if using)
DATABASE_URL=sqlite:///skyvault.db

# WebAuthn / FIDO2 — change these for your production domain
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=SkyVault
WEBAUTHN_ORIGIN=http://localhost:5000

# Set to 'True' to enable HSTS (Strict-Transport-Security) — only use on HTTPS deployments
ENABLE_HTTPS=False